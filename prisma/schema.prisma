generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// LAYER RBAC
// ============================================================

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles      UserRole[]
  pasien     Pasien?
  rekamMedis RekamMedis[]
  jadwal     Jadwal[]
  pembayaran Pembayaran[]
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ============================================================
// LAYER DOMAIN KLINIK
// ============================================================

model Pasien {
  id           String   @id @default(uuid())
  noRM         String   @unique
  nama         String
  tglLahir     DateTime
  jenisKelamin String
  alamat       String?
  noTelp       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  rekamMedis RekamMedis[]
  antrian    Antrian[]
}

model RekamMedis {
  id         String   @id @default(uuid())
  keluhan    String   @db.Text
  diagnosa   String   @db.Text
  resep      String?  @db.Text
  tglPeriksa DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pasienId String
  pasien   Pasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  dokterId String
  dokter   User   @relation(fields: [dokterId], references: [id], onDelete: Restrict)

  antrianId String?  @unique
  antrian   Antrian? @relation(fields: [antrianId], references: [id], onDelete: SetNull)
}

model Jadwal {
  id         String   @id @default(uuid())
  hari       String
  jamMulai   String
  jamSelesai String
  kuota      Int      @default(20)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  dokterId String
  dokter   User   @relation(fields: [dokterId], references: [id], onDelete: Cascade)

  antrian Antrian[]
}

model Antrian {
  id           String   @id @default(uuid())
  nomorAntrian Int
  status       String   @default("MENUNGGU")
  tglDaftar    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pasienId String
  pasien   Pasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  jadwalId String
  jadwal   Jadwal @relation(fields: [jadwalId], references: [id], onDelete: Restrict)

  rekamMedis RekamMedis?
  pembayaran Pembayaran?
}

model Pembayaran {
  id          String    @id @default(uuid())
  jumlah      Decimal   @db.Decimal(12, 2)
  status      String    @default("BELUM_BAYAR")
  metodeBayar String?
  tglBayar    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  antrianId String  @unique
  antrian   Antrian @relation(fields: [antrianId], references: [id], onDelete: Cascade)

  kasirId String?
  kasir   User?   @relation(fields: [kasirId], references: [id], onDelete: SetNull)
}